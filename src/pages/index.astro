---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getHomeJsonLd, getSiteTitle, liveGameCount } from '../data/games';
import { SITE_DESCRIPTION } from '../data/site';
---

<BaseLayout
  title={getSiteTitle('Home')}
  description={SITE_DESCRIPTION}
  currentPage="home"
  jsonLd={getHomeJsonLd()}
>
  <section class="hero">
    <span class="kicker">tuffest games oat</span>
    <h1>We've been proudly underdelivering since FOREVER.</h1>
    <p class="lead">We produce the most niche Roblox games of all time.</p>
    <div class="cta-row">
      <a class="button primary" href="/games">Explore games</a>
      <a class="button ghost" href="/blogs">Read updates</a>
    </div>
  </section>

  <div class="stat-strip" aria-label="Studio stats">
    <div class="stat-item">
      <span class="stat-value">{liveGameCount}</span>
      <h2>Live Games</h2>
      <p>Released Roblox games currently available to play.</p>
    </div>
    <div class="stat-item">
      <span class="stat-value">67+</span>
      <h2>Updates Shipped</h2>
      <p>Balance passes, patch fixes, silent updates and feature drops this year.</p>
    </div>
    <div class="stat-item">
      <span class="stat-value">300k+</span>
      <h2>Cumulative Visits</h2>
      <p>Adding up every single visit from every game.</p>
    </div>
  </div>
</BaseLayout>

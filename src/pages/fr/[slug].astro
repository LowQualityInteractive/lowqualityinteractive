---
import type { GetStaticPaths } from 'astro';
import { publishedGameSlugs } from '../../data/games';
import GamePage from '../../views/GamePage.astro';

export const getStaticPaths: GetStaticPaths = () =>
  publishedGameSlugs.map((slug) => ({
    params: { slug },
    props: { slug },
  }));

interface Props {
  slug: string;
}

const { slug } = Astro.props;
---

<GamePage locale="fr" slug={slug} />

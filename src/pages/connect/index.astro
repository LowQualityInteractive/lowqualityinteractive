---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Low Quality Interactive | Connect"
  description="Join our community today!"
  currentPage="connect"
>
  <section class="hero">
    <span class="kicker">please dont connect with us</span>
    <h1>Connect with us</h1>
    <p class="lead">Follow the studio and join the community across our official channels.</p>
  </section>

  <div class="platform-grid" aria-label="Connect platforms">
    <a class="platform-card" href="https://discord.gg/G2J9rP5fBg" target="_blank" rel="noopener noreferrer" aria-label="Discord">
      <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
        <path d="M20.3 4.37A19.8 19.8 0 0 0 15.4 3c-.2.36-.43.84-.6 1.22a18.3 18.3 0 0 0-5.58 0c-.18-.38-.42-.86-.61-1.22-1.7.3-3.35.77-4.91 1.37C.57 9.07-.24 13.65.17 18.17a19.9 19.9 0 0 0 6.03 3.02c.49-.67.92-1.39 1.29-2.15-.7-.26-1.37-.59-2-.97.17-.12.34-.25.5-.38 3.86 1.8 8.05 1.8 11.86 0 .17.14.34.27.5.38-.63.38-1.31.71-2 .97.37.76.8 1.48 1.29 2.15a19.8 19.8 0 0 0 6.03-3.02c.49-5.24-.84-9.78-3.37-13.8ZM8.02 15.39c-1.15 0-2.09-1.05-2.09-2.34s.93-2.34 2.09-2.34c1.16 0 2.1 1.05 2.09 2.34 0 1.29-.93 2.34-2.09 2.34Zm7.96 0c-1.15 0-2.09-1.05-2.09-2.34s.93-2.34 2.09-2.34c1.16 0 2.1 1.05 2.09 2.34 0 1.29-.93 2.34-2.09 2.34Z" />
      </svg>
      <span>Discord</span>
    </a>
    <a class="platform-card" href="https://www.youtube.com/@LowQualityInteractive" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
      <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
        <path d="M23.5 6.2a3.04 3.04 0 0 0-2.14-2.15C19.45 3.5 12 3.5 12 3.5s-7.45 0-9.36.55A3.04 3.04 0 0 0 .5 6.2 31.3 31.3 0 0 0 0 12a31.3 31.3 0 0 0 .5 5.8 3.04 3.04 0 0 0 2.14 2.15c1.91.55 9.36.55 9.36.55s7.45 0 9.36-.55a3.04 3.04 0 0 0 2.14-2.15A31.3 31.3 0 0 0 24 12a31.3 31.3 0 0 0-.5-5.8ZM9.6 15.57V8.43L15.82 12 9.6 15.57Z" />
      </svg>
      <span>YouTube</span>
    </a>
    <a class="platform-card" href="https://www.roblox.com/communities/7489017/Low-Quality-Int#!/about" target="_blank" rel="noopener noreferrer" aria-label="Roblox group">
      <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
        <path d="M5.5 2.5L2.5 18.5L18.5 21.5L21.5 5.5L5.5 2.5Z" />
        <path fill="var(--surface)" d="M10.5 10L9.75 13.75L13.5 14.5L14.25 10.75L10.5 10Z" />
      </svg>
      <span>Roblox Group</span>
    </a>
    <a class="platform-card" href="https://x.com/LowQualityInt" target="_blank" rel="noopener noreferrer" aria-label="X">
      <svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
        <path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z" />
      </svg>
      <span>X</span>
    </a>
  </div>

  <div class="email-contact">
    <h2>Business Inquiries</h2>
    <p>For partnerships, licensing, or other business matters:</p>
    <div class="email-row">
      <span class="email-address">contact@lowqualityinteractive.com</span>
      <button class="copy-btn" id="copy-email" aria-label="Copy email address">
        <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="9" y="9" width="13" height="13" rx="2" />
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1" />
        </svg>
        <span id="copy-label">Copy</span>
      </button>
    </div>
  </div>
</BaseLayout>

<script>
  const btn = document.getElementById('copy-email');
  const label = document.getElementById('copy-label');
  btn?.addEventListener('click', async () => {
    await navigator.clipboard.writeText('contact@lowqualityinteractive.com');
    label!.textContent = 'Copied!';
    setTimeout(() => { label!.textContent = 'Copy'; }, 2000);
  });
</script>

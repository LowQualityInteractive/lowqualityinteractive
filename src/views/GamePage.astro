---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  getGameBySlug,
  getGameAboutPath,
  getGameJsonLd,
  getGameUpdateHref,
} from '../data/games';
import { getSiteTitle, toAbsoluteSiteUrl } from '../data/site';
import { getLocalePath, getMessages, type Locale } from '../i18n/messages';

interface Props {
  locale: Locale;
  slug: string;
}

const { locale, slug } = Astro.props;
const messages = getMessages(locale);
const page = messages.pages.game;
const game = getGameBySlug(locale, slug);

if (!game) {
  throw new Error(`Unknown game slug: ${slug}`);
}
---

<BaseLayout
  locale={locale}
  title={getSiteTitle(game.name)}
  description={game.pageDescription}
  currentPage="games"
  routePath={game.slug}
  jsonLd={getGameJsonLd(locale, game)}
  ogImage={game.artwork.src}
>
  <link slot="head-extra" rel="about" href={toAbsoluteSiteUrl(getGameAboutPath(locale, game))} />
  <section class="hero">
    <span class="kicker">{page.kicker}</span>
    <h1>{game.name}</h1>
    <p class="lead">{game.pageLead}</p>
    <div class="cta-row">
      <a class="button primary button-play" target="_blank" rel="noopener noreferrer" href={game.robloxUrl}>{page.openGame}</a>
      <a class="button ghost" href={getGameUpdateHref(locale, game)}>{page.latestUpdate}</a>
      <a class="button ghost" href={getLocalePath(locale, 'games')}>{page.backToGames}</a>
    </div>
  </section>
</BaseLayout>

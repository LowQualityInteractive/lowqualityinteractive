---
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  getGameBySlug,
  getGameAboutJsonLd,
  getGameHref,
  getGameUpdateHref,
} from '../data/games';
import { getSiteTitle, SITE_NAME, toAbsoluteSiteUrl } from '../data/site';
import { getMessages, sanitizeInlineScript, type Locale } from '../i18n/messages';
import { getAboutTranslateScript } from '../scripts/translate';

interface Props {
  locale: Locale;
  slug: string;
}

const { locale, slug } = Astro.props;
const messages = getMessages(locale);
const page = messages.pages.game;
const statusLabels = messages.chrome.status;
const game = getGameBySlug(locale, slug);

if (!game) {
  throw new Error(`Unknown game slug: ${slug}`);
}

const aboutRoutePath = `${game.slug}/about`;
const statusLabel = statusLabels[game.status as keyof typeof statusLabels] ?? game.status;
const aboutLabels = page.about ?? {
  kicker: 'About this game',
  developer: 'Developer',
  platform: 'Platform',
  genre: 'Genre',
  status: 'Status',
  featuresHeading: 'Features',
  linksHeading: 'Official links',
};

// Load game-about.json at build time
let aboutData: {
  body: string[];
  features: string[];
  media: { src: string; alt: string; caption?: string }[];
  links: { label: string; href: string; external: boolean }[];
} = { body: [], features: [], media: [], links: [] };

try {
  const raw = JSON.parse(readFileSync(resolve('public/data/game-about.json'), 'utf-8'));
  const entry = raw.games?.find((g: { id: string }) => g.id === game.id);
  if (entry) aboutData = entry;
} catch {}

const aboutTranslateScript = sanitizeInlineScript(getAboutTranslateScript());
---

<BaseLayout
  locale={locale}
  title={getSiteTitle(`About ${game.name}`)}
  description={game.pageDescription}
  currentPage="games"
  routePath={aboutRoutePath}
  jsonLd={getGameAboutJsonLd(locale, game)}
  ogImage={game.artwork.src}
  extraScripts={[aboutTranslateScript]}
>
  <link slot="head-extra" rel="up" href={toAbsoluteSiteUrl(getGameHref(locale, game))} />

  <section class="hero">
    <span class="kicker">{aboutLabels.kicker}</span>
    <h1>{game.name}</h1>
    <p class="lead">{game.pageLead}</p>
    <div class="cta-row">
      <a class="button primary button-play" target="_blank" rel="noopener noreferrer" href={game.robloxUrl}>{page.openGame}</a>
      <a class="button ghost" href={getGameUpdateHref(locale, game)}>{page.latestUpdate}</a>
      <a class="button ghost" href={getGameHref(locale, game)}>{page.backToGames}</a>
    </div>
  </section>

  <section class="about-details">
    <!-- Metadata grid -->
    <dl class="about-grid">
      <div class="about-entry">
        <dt>{aboutLabels.developer}</dt>
        <dd>{SITE_NAME}</dd>
      </div>
      <div class="about-entry">
        <dt>{aboutLabels.platform}</dt>
        <dd>Roblox</dd>
      </div>
      <div class="about-entry">
        <dt>{aboutLabels.genre}</dt>
        <dd>{game.genreLabel}</dd>
      </div>
      <div class="about-entry">
        <dt>{aboutLabels.status}</dt>
        <dd>{statusLabel}</dd>
      </div>
    </dl>

    <!-- Media gallery -->
    {aboutData.media.length > 0 && (
      <div class="about-media">
        {aboutData.media.map((item) => (
          <figure class="about-media-item">
            <img src={item.src} alt={item.alt} loading="lazy" />
            {item.caption && <figcaption data-translatable>{item.caption}</figcaption>}
          </figure>
        ))}
      </div>
    )}

    <!-- Body paragraphs -->
    {aboutData.body.length > 0 && (
      <div class="about-body" id="about-body">
        {aboutData.body.map((para) => (
          <p data-translatable>{para}</p>
        ))}
      </div>
    )}

    <!-- Features list -->
    {aboutData.features.length > 0 && (
      <div class="about-features">
        <h2>{aboutLabels.featuresHeading}</h2>
        <ul id="about-features-list">
          {aboutData.features.map((feat) => (
            <li data-translatable>{feat}</li>
          ))}
        </ul>
      </div>
    )}

    <!-- Links -->
    {aboutData.links.length > 0 && (
      <div class="about-links">
        <h2>{aboutLabels.linksHeading}</h2>
        <ul>
          {aboutData.links.map((link) => (
            <li>
              <a
                href={link.href}
                target={link.external ? '_blank' : undefined}
                rel={link.external ? 'noopener noreferrer' : undefined}
                data-translatable
              >{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    )}

    <!--
      LLM context: This page is the canonical about page for {game.name} by {SITE_NAME}.
      Genre: {game.genreLabel}. Platform: Roblox.
      Official Roblox URL: {game.robloxUrl}
    -->
  </section>
</BaseLayout>
